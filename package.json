{
  "name": "iptv",
  "private": true,
  "version": "3.0.3",
  "description": "Premium IPTV Web Player and App",
  "author": "Mohamed",
  "repository": {
    "type": "git",
    "url": "https://github.com/mohamed438201/iptv-web"
  },
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development concurrently \"npm run dev\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:publish": "npm run build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.ugeen.iptv",
    "productName": "IPTV Premium",
    "icon": "public/logo.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "copyright": "Copyright © 2026 Mohamed",
    "publish": [
      {
        "provider": "github",
        "owner": "mohamed438201",
        "repo": "iptv-web"
      }
    ]
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capgo/capacitor-updater": "^8.49.7",
    "@supabase/supabase-js": "^2.108.2",
    "axios": "^1.18.1",
    "cors": "^2.8.6",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.18.0",
    "mysql2": "^3.22.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-phone-number-input": "^3.4.17",
    "react-router-dom": "^7.18.0",
    "react-youtube": "^10.1.0",
    "uuid": "^14.0.1",
    "video.js": "^8.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "javascript-obfuscator": "^5.4.3",
    "vite": "^8.0.12",
    "vite-plugin-javascript-obfuscator": "^3.1.0"
  }
}